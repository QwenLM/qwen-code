# Qwen Code Environment Variables
# Copy this file to .env and fill in your values

# NVIDIA NIM Provider (auto-selects when set)
# Get your API key from: https://build.nvidia.com/
NVIDIA_API_KEY=your_key_here

# Optional: Custom base URL for NVIDIA NIM (defaults to https://integrate.api.nvidia.com/v1)
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional: Custom model for NVIDIA NIM (defaults to qwen/qwen2.5-coder-32b-instruct)
# NVIDIA_MODEL=qwen/qwen2.5-coder-32b-instruct

# --- Other Providers ---

# Qwen OAuth (set to enable OAuth flow)
# QWEN_OAUTH=true

# OpenAI Provider
# OPENAI_API_KEY=your_key_here
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini Provider
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Vertex AI Provider
# GOOGLE_API_KEY=your_key_here
# GOOGLE_MODEL=gemini-2.0-flash

# Anthropic Provider
# ANTHROPIC_API_KEY=your_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
