{
  "name": "@qwen-code/mcp-chrome-integration",
  "version": "2.0.0",
  "private": true,
  "author": "Qwen Team",
  "description": "Qwen Code Chrome Integration - daemon-direct extension that connects to a local `qwen serve` daemon",
  "type": "module",
  "scripts": {
    "build:extension": "npm --prefix app/chrome-extension run build",
    "build": "npm run build:extension",
    "dev:extension": "npm --prefix app/chrome-extension run dev",
    "dev": "npm run dev:extension",
    "clean:dist": "npm --prefix app/chrome-extension run clean",
    "clean:modules": "rm -rf node_modules app/chrome-extension/node_modules",
    "clean": "npm run clean:dist && npm run clean:modules"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.25.1",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vue-eslint-parser": "^10.1.3"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,yaml,html,css}": [
      "prettier --write"
    ]
  }
}
