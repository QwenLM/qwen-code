{
  "name": "@qwen-code/chat-panel",
  "version": "0.0.0",
  "description": "Shared, props-driven chat panel (input composer + conversation flow) reused by web-shell, the VSCode webview, and the desktop app.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@qwen-code/webui": ">=0.0.1",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
