From: fork-maintainer <fork@qwen-code.local>
Subject: [PATCH] feat(channels): use fork feishu package name in channel registry

Keep the fork's @alife/dataworks-qwen-code-channel-feishu package name
in the CLI channel registry import. The feishu source code itself now
follows upstream (PR #4379); only the published npm package name differs.

Package.json name/registry handled by .fork/rewrite-package-identity.js.

diff --git a/packages/cli/src/commands/channel/channel-registry.ts b/packages/cli/src/commands/channel/channel-registry.ts
index 90df33214..520ed46a2 100644
--- a/packages/cli/src/commands/channel/channel-registry.ts
+++ b/packages/cli/src/commands/channel/channel-registry.ts
@@ -10,7 +10,7 @@ function ensureBuiltins(): Promise<void> {
         import('@qwen-code/channel-telegram'),
         import('@qwen-code/channel-weixin'),
         import('@qwen-code/channel-dingtalk'),
-        import('@qwen-code/channel-feishu'),
+        import('@alife/dataworks-qwen-code-channel-feishu'),
       ]);
 
       for (const mod of [telegram, weixin, dingtalk, feishu]) {
