+      imGroupOpenSpaceModel: {
+        supportForward: true,
+      },
+      imGroupOpenDeliverModel: {
+        robotCode: this.config.clientId,
+      },
+      cardData: {
+        cardParamMap: {
+          content: text,
+          flowStatus: '2', // INPUTING
+        },
+      },
