# Copy to .env and fill in your STAGING (NOT production) OSS credentials.
# .env is gitignored.

# Aliyun RAM AccessKey scoped to the staging bucket only
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# Bucket name. MUST NOT be the production bucket "qwen-code-assets".
OSS_BUCKET=

# Region endpoint, e.g. oss-cn-hangzhou.aliyuncs.com
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# Object key prefix. Default: installation
# OSS_PREFIX=installation
