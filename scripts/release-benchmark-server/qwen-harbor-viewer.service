[Unit]
Description=Qwen Harbor results viewer
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ecs-user
Group=ecs-user
WorkingDirectory=/home/ecs-user/qwen-benchmark
ExecStart=/home/ecs-user/qwen-benchmark/.venv/bin/harbor view /home/ecs-user/qwen-benchmark/jobs --jobs --host 127.0.0.1 --port 8080
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
